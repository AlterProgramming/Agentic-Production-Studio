{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentic-production-studio.local/schemas/builder-plan-v1.json",
  "title": "Studio Surgical Builder Plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "plan_id", "allowed_paths", "operations"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "plan_id": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "allowed_paths": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "preconditions": {"type": "array", "items": {"$ref": "#/$defs/condition"}},
    "operations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "type"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "type": {"enum": ["copy_file", "delete_file", "image_normalize", "json_patch", "replace_text", "write_text"]}
        }
      }
    },
    "postconditions": {"type": "array", "items": {"$ref": "#/$defs/condition"}}
  },
  "$defs": {
    "condition": {
      "type": "object",
      "required": ["type", "path"],
      "properties": {
        "id": {"type": "string"},
        "type": {"enum": ["exists", "json_pointer_equals", "max_bytes", "sha256", "text_contains"]},
        "path": {"type": "string", "minLength": 1},
        "pointer": {"type": "string"},
        "value": {}
      }
    }
  }
}
